# Database connection URL (change this to your local or hosted PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/splitwise

# Secret key for JWT token signing (change this to a secure random string in production)
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# Port for the Express server to run on
PORT=5001

# Enable/disable quick switcher demo mode
DEMO_MODE=true

# Environment setting (development, production)
NODE_ENV=development

# Currency rate conversion factor (1 USD to INR)
USD_TO_INR_RATE=84
